    {
      "parameters": {
        "jsCode": "// هنجيب النص اللي طالع من الـ AI\nlet text = $json.output || \"\"; \n\n// 1. مسح الجملة المزعجة بأي شكل تظهر بيه (حتى لو الحروف متقطعة)\ntext = text.replace(/Here are (two )?helpful.*get you started:?/gi, '');\ntext = text.replace(/Here are some helpful links:?/gi, '');\n\n// 2. مسح أي أقواس مربعة أو مدورة فاضية أو جواها كلام (بقايا اللينكات)\ntext = text.replace(/\\[.*?\\]/g, ''); // بيمسح أي حاجة بين [ ]\ntext = text.replace(/\\(.*?\\)/g, ''); // بيمسح أي حاجة بين ( )\n\n// 3. مسح كلمة \"لينك\" أو \"link\" أو \"Screenpal\"\ntext = text.replace(/(لينك|رابط|اللينك|الرابط|link|links|screenpal)/gi, '');\n\n// 5. تنظيف المسافات الزيادة والسطور الجديدة والرموز الغريبة اللي باقية\nconst cleanText = text.replace(/\\n/g, ' ')      // تحويل السطور الجديدة لمسافات\n                      .replace(/\\s\\s+/g, ' ')   // مسح المسافات المتكررة\n                      .replace(/[:\\.]\\s*$/g, '') // مسح النقطة أو النقطتين لو في آخر الجملة\n                      .trim();\n\nreturn {\n  output: cleanText\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
