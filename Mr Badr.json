        "jsCode": "// خذ نص رد البوت من النود اللي قبله\nconst botResponse = $input.item.json.output || \"\"; \n\n// لينك المنصة الثابت\nconst platformLink = \"https://i3tamid.om/\";\n\n// جدول الروابط بناءً على ملفات سوبابيز اللي رفعتها\nconst links = {\n  'Leadership': 'https://mgqtjshmbcelhxksnlfz.supabase.co/storage/v1/object/public/i3tamid/Leadership_Classification_Job_Description_Form_Formatted.docx',\n  'Specialist': 'https://mgqtjshmbcelhxksnlfz.supabase.co/storage/v1/object/public/i3tamid/Specialist_Level_Job_Description_Form_English.docx',\n  'Technical': 'https://mgqtjshmbcelhxksnlfz.supabase.co/storage/v1/object/public/i3tamid/Technical_Level_Job_Description_Form_English.docx',\n  'Supervisory': 'https://mgqtjshmbcelhxksnlfz.supabase.co/storage/v1/object/public/i3tamid/Supervisory_classification_Job_Description%20form.docx',\n  'ClassificationSteps': 'https://mgqtjshmbcelhxksnlfz.supabase.co/storage/v1/object/public/i3tamid/Professional%20Classification%20Steps.pdf',\n  'LicensingSteps': 'https://mgqtjshmbcelhxksnlfz.supabase.co/storage/v1/object/public/i3tamid/Professional%20Licensing%20Steps.pdf'\n};\n\n// البحث عن التصنيف جوه رد البوت\nlet selectedLink = \"\";\nif (botResponse.includes('Leadership')) selectedLink = links.Leadership;\nelse if (botResponse.includes('Specialist')) selectedLink = links.Specialist;\nelse if (botResponse.includes('Technical')) selectedLink = links.Technical;\nelse if (botResponse.includes('Supervisory')) selectedLink = links.Supervisory;\nelse if (botResponse.includes('التصنيف المهني') || botResponse.includes('Classification')) selectedLink = links.ClassificationSteps;\nelse if (botResponse.includes('الترخيص المهني') || botResponse.includes('مزاولة المهنة') || botResponse.includes('Licensing')) selectedLink = links.LicensingSteps;\n\n// تجهيز الرسالة النهائية\nlet finalMessage = \"\";\n\nif (selectedLink !== \"\") {\n    // لو فيه استمارة أو ملف خطوات، يبعت رابط الملف ورابط المنصة\n    finalMessage = `تفضل الرابط الخاص بطلبك:\\n${selectedLink}\\n\\nرابط المنصة:\\n${platformLink}`;\n} else {\n    // لو مفيش تصنيف (رد عام)، يبعت رابط المنصة بس\n    finalMessage = `رابط المنصة:\\n${platformLink}`;\n}\n\nreturn {\n    message: finalMessage,\n    selectedLink: selectedLink\n};"
      },
